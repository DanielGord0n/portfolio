.timeline-container {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 0;
}

.timeline-container::after {
    content: '';
    position: absolute;
    width: 2px;
    background-color: var(--accent-primary);
    top: 0;
    bottom: 0;
    left: 50%;
    margin-left: -1px;
}

.timeline-item {
    padding: 10px 40px;
    position: relative;
    background-color: inherit;
    width: 50%;
    box-sizing: border-box;
}

.timeline-item:nth-child(odd) {
    left: 0;
}

.timeline-item:nth-child(even) {
    left: 50%;
}

.timeline-item::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    right: -10px;
    background-color: var(--bg-primary);
    border: 4px solid var(--accent-primary);
    top: 15px;
    border-radius: 50%;
    z-index: 1;
}

.timeline-item:nth-child(even)::after {
    left: -10px;
}

.timeline-content {
    padding: 20px 30px;
    background-color: var(--bg-secondary);
    position: relative;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.timeline-content:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-hover-shadow);
    border-color: var(--accent-primary);
}

.timeline-period {
    font-family: 'Fira Code', monospace;
    color: var(--accent-primary);
    font-size: 0.9rem;
    display: block;
    margin-bottom: 10px;
}

.timeline-role {
    margin: 0 0 5px 0;
    color: var(--text-primary);
    font-size: 1.2rem;
}

.timeline-company {
    margin: 0 0 15px 0;
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 400;
}

.timeline-description {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.6;
}

@media screen and (max-width: 600px) {
    .timeline-container::after {
        left: 31px;
    }

    .timeline-item {
        width: 100%;
        padding-left: 70px;
        padding-right: 25px;
    }

    .timeline-item::after {
        left: 21px;
    }

    .timeline-item:nth-child(even) {
        left: 0%;
    }
}